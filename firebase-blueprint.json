{
  "entities": {
    "Presentation": {
      "title": "Presentation",
      "description": "A generated presentation with slides and sources",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique ID of the presentation" },
        "userId": { "type": "string", "description": "Owner of the presentation" },
        "topic": { "type": "string", "description": "The topic of the presentation" },
        "presentationTitle": { "type": "string", "description": "The title of the presentation" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" },
        "slides": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "number" },
              "title": { "type": "string" },
              "bulletPoints": { "type": "array", "items": { "type": "string" } },
              "speakerNotes": { "type": "string" },
              "imageUrl": { "type": "string" },
              "audioUrl": { "type": "string" },
              "layout": { "type": "string" },
              "shape": { "type": "string" },
              "x": { "type": "number" },
              "y": { "type": "number" }
            }
          }
        },
        "sources": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "title": { "type": "string" },
              "uri": { "type": "string" }
            }
          }
        }
      },
      "required": ["userId", "topic", "presentationTitle", "slides", "createdAt"]
    }
  },
  "firestore": {
    "/presentations/{presentationId}": {
      "schema": "Presentation",
      "description": "Stored presentations"
    }
  }
}
